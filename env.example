# Grafana Configuration
# Change these values in Coolify's Environment Variables section

# Grafana admin username
GRAFANA_ADMIN_USER=admin

# Grafana admin password - CHANGE THIS!
GRAFANA_ADMIN_PASSWORD=your_secure_password

# Grafana Configuration
# Set to your Coolify domain
GRAFANA_ROOT_URL=https://grafana.yourdomain.com
GRAFANA_DOMAIN=grafana.yourdomain.com

# Loki Configuration (optional - for direct access)
# Set to your Coolify domain if you want to expose Loki
LOKI_ROOT_URL=https://loki.yourdomain.com

# Promtail Configuration (optional - for monitoring)
# Set to your Coolify domain if you want to expose Promtail metrics
PROMTAIL_ROOT_URL=https://promtail.yourdomain.com

# Optional: Path to Laravel logs if mounting directly
# LARAVEL_LOGS_PATH=/path/to/laravel/storage/logs
